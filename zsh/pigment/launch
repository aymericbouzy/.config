#!/usr/bin/env sh

set -e

# Parse command line arguments
ENABLE_NPM=true
ENABLE_FRONT_BUILD=true
ENABLE_FRONT_GENERATE=true
ENABLE_DOTNET_BUILD=true
ENABLE_TONER=true

while [ $# -gt 0 ]; do
	case "$1" in
	--no-npm)
		ENABLE_NPM=false
		;;
	--no-front-build)
		ENABLE_FRONT_BUILD=false
		;;
	--no-dotnet-build)
		ENABLE_DOTNET_BUILD=false
		;;
	--no-toner)
		ENABLE_TONER=false
		;;
	*)
		echo "Unknown option: $1"
		echo "Usage: $0 [--no-npm] [--no-front-build] [--no-dotnet-build] [--no-toner]"
		exit 1
		;;
	esac
	shift
done

REPO_PATH="$(git rev-parse --show-toplevel)"

# Group 1: npm + generate (parallel) -> front build
(
	if [ "$ENABLE_NPM" = true ]; then
		(cd "$REPO_PATH/apps/Front" && npm install) &
		NPM_PID=$!
	fi

	if [ "$ENABLE_FRONT_GENERATE" = true ]; then
		(cd "$REPO_PATH/apps/Front" && npm run generate) &
		GENERATE_PID=$!
	fi

	[ "$ENABLE_NPM" = true ] && wait "$NPM_PID"
	[ "$ENABLE_FRONT_GENERATE" = true ] && wait "$GENERATE_PID"

	if [ "$ENABLE_FRONT_BUILD" = true ]; then
		cd "$REPO_PATH/apps/Front/packages/app-pigment"
		npm run build:nospreadjs
		npm run serve
	fi
) &
GROUP1_PID=$!

# Group 2: toner + dotnet (parallel) -> stack up
(
	if [ "$ENABLE_TONER" = true ]; then
		(
			toner self-update
			toner stack generate \
				--mode registry \
				--modePerServiceType.csharp docker-prebuilt-nopublish \
				--flavors default,local-storage
		) &
		TONER_PID=$!
	fi

	if [ "$ENABLE_DOTNET_BUILD" = true ]; then
		(build all) &
		DOTNET_PID=$!
	fi

	[ "$ENABLE_TONER" = true ] && wait "$TONER_PID"
	[ "$ENABLE_DOTNET_BUILD" = true ] && wait "$DOTNET_PID"

	stack up -d --build --remove-orphans
) &
GROUP2_PID=$!

wait "$GROUP1_PID" "$GROUP2_PID"
