#!/usr/bin/env sh

set -e

# propagate the signal to all child processes
cleanup() {
	kill 0
}
trap cleanup INT TERM

# Parse command line arguments
ENABLE_FRONT=false
ENABLE_FRONT_SERVE=false
ENABLE_DOTNET_BUILD=true
ENABLE_TONER=true

usage() {
	echo "Usage: $0 [--front] [--serve] [--no-dotnet-build] [--no-toner]"
	exit 1
}

while [ $# -gt 0 ]; do
	case "$1" in
	--front)
		ENABLE_FRONT=true
		;;
	--serve)
		ENABLE_FRONT_SERVE=true
		;;
	--no-dotnet-build)
		ENABLE_DOTNET_BUILD=false
		;;
	--no-toner)
		ENABLE_TONER=false
		;;
	--help)
		usage
		;;
	*)
		echo "Unknown option: $1"
		usage
		;;
	esac
	shift
done

REPO_PATH="$(git rev-parse --show-toplevel)"

# Group 1: pnpm + generate + front build
(
	if [ "$ENABLE_FRONT" = true ]; then
		cd "$REPO_PATH/apps/Front"
		pnpm install
		pnpm generate

		cd "$REPO_PATH/apps/Front/packages/app-pigment"
		pnpm build:nospreadjs
	fi
) &
GROUP1_PID=$!

# Group 2: toner + dotnet (parallel) -> stack up
(
	if [ "$ENABLE_TONER" = true ]; then
		(
			# toner fails when already up to date
			toner self-update || true
			toner stack generate \
				--mode registry \
				--modePerServiceType.csharp docker-prebuilt-nopublish \
				--flavors default,local-storage

			stack down
		) &
		TONER_PID=$!
	fi

	if [ "$ENABLE_DOTNET_BUILD" = true ]; then
		(build all) &
		DOTNET_PID=$!
	fi

	[ "$ENABLE_TONER" = true ] && wait "$TONER_PID"
	[ "$ENABLE_DOTNET_BUILD" = true ] && wait "$DOTNET_PID"

	stack up -d --build --remove-orphans
) &
GROUP2_PID=$!

wait "$GROUP1_PID" "$GROUP2_PID"

if [ "$ENABLE_FRONT_SERVE" = true ]; then
	(
		cd "$REPO_PATH/apps/Front/packages/app-pigment"
		pnpm serve
	)
fi
